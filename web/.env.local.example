# Mock API mode (default off — everything hits the real backend):
#   0                    — no MSW; every request hits the backend (default)
#   1                    — all MSW handlers active (frontend-only iteration, no backend needed)
#   1,-auth              — mostly mocked, real auth
#   auth,events          — only those domains mocked, rest hit backend
NEXT_PUBLIC_MOCK_API=0

# Base for the REST API. Keep "/api" for same-origin (Next proxy or PWA).
# Override to a full URL when the backend is on a different host in dev.
NEXT_PUBLIC_API_BASE=/api

# Enable Next.js dev proxy: /api/* forwards to the Spring Boot backend.
# Unset to disable (e.g. when using only mocks or a full backend URL).
BACKEND_PROXY_TARGET=http://localhost:8080

# WebSocket base for STOMP. Resolved at runtime from window.location in production;
# this is only used during SSR / build, where no real WS is opened.
NEXT_PUBLIC_WS_ORIGIN=ws://localhost:8080
