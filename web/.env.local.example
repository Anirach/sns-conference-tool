# Mock API mode:
#   1                    — all MSW handlers active (Pass 1 default)
#   0                    — no MSW; every request hits the backend
#   1,-auth              — all except auth (Phase 1 cutover)
#   1,-auth,-profile     — all except auth+profile (Phase 1 full cutover)
#   auth,events          — only those domains mocked, rest hit backend
NEXT_PUBLIC_MOCK_API=1

# Base for the REST API. Keep "/api" for same-origin (Next proxy or WebView).
# Override to a full URL when the backend is on a different host in dev.
NEXT_PUBLIC_API_BASE=/api

# Enable Next.js dev proxy: /api/* forwards to the Spring Boot backend.
# Unset to disable (e.g. when using only mocks or a full backend URL).
# BACKEND_PROXY_TARGET=http://localhost:8080

# WebSocket base for STOMP (Phase 3).
NEXT_PUBLIC_WS_ORIGIN=ws://localhost:8080
