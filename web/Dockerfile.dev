# Dev-mode container for the Next.js frontend.
#
# Runs `next dev` so HMR + fast refresh keep working while the project source is bind-mounted
# from the host. For production builds see web/Dockerfile (used by the `web-prod` compose
# profile and deploy-web.yml).
#
# Two-stage build: stage 1 hydrates node_modules in the image (so a cold container start
# doesn't re-resolve every dependency); stage 2 is the runtime that next dev runs in.

FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci --no-audit --no-fund

FROM node:22-alpine AS dev
WORKDIR /app
# Bring the resolved node_modules forward; the bind mount in compose overlays src/.
COPY --from=deps /app/node_modules ./node_modules
COPY . .
EXPOSE 3000
ENV NEXT_TELEMETRY_DISABLED=1
CMD ["npm", "run", "dev"]
