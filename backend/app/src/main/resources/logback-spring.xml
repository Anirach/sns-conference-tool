<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty name="APP_NAME" source="spring.application.name" defaultValue="sns-backend"/>
    <springProperty name="PROFILE" source="spring.profiles.active" defaultValue="dev"/>

    <!--
      Two appenders: CONSOLE_PLAIN during local dev (readable lines), CONSOLE_JSON in prod
      (shippable to Loki / ELK). The profile switch keeps stack traces structured without
      polluting local output with JSON.

      Both appenders run messages through PiiScrubber so emails, JWTs, and high-precision
      GPS coordinates are redacted before leaving the process.
    -->

    <conversionRule conversionWord="piiMsg"
                    converterClass="com.sns.app.config.PiiMaskingPatternConverter"/>

    <appender name="CONSOLE_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%X{requestId:-}] %logger{36} - %piiMsg%n</pattern>
        </encoder>
    </appender>

    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.composite.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp>
                    <fieldName>ts</fieldName>
                    <pattern>yyyy-MM-dd'T'HH:mm:ss.SSSXXX</pattern>
                </timestamp>
                <logLevel>
                    <fieldName>level</fieldName>
                </logLevel>
                <loggerName>
                    <fieldName>logger</fieldName>
                </loggerName>
                <threadName>
                    <fieldName>thread</fieldName>
                </threadName>
                <provider class="com.sns.app.config.PiiMaskingMessageJsonProvider"/>
                <mdc/>
                <stackTrace>
                    <fieldName>stack</fieldName>
                </stackTrace>
                <pattern>
                    <pattern>
                        {"app": "${APP_NAME}", "env": "${PROFILE}"}
                    </pattern>
                </pattern>
            </providers>
        </encoder>
    </appender>

    <root level="INFO">
        <springProfile name="prod,staging">
            <appender-ref ref="CONSOLE_JSON"/>
        </springProfile>
        <springProfile name="!prod &amp; !staging">
            <appender-ref ref="CONSOLE_PLAIN"/>
        </springProfile>
    </root>

    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.springframework.boot" level="INFO"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="com.sns" level="INFO"/>
</configuration>
