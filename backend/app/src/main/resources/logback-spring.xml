<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty name="APP_NAME" source="spring.application.name" defaultValue="sns-backend"/>
    <springProperty name="PROFILE" source="spring.profiles.active" defaultValue="dev"/>

    <!--
      Two appenders: CONSOLE_PLAIN during local dev (readable lines), CONSOLE_JSON in prod
      (shippable to Loki / ELK). The profile switch keeps stack traces structured without
      polluting local output with JSON.
    -->

    <appender name="CONSOLE_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%X{requestId:-}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"app":"${APP_NAME}","env":"${PROFILE}"}</customFields>
            <includeMdc>true</includeMdc>
            <!-- PII masking: redact email addresses anywhere in a log line. -->
            <fieldNames>
                <timestamp>ts</timestamp>
                <level>level</level>
                <logger>logger</logger>
                <thread>thread</thread>
                <message>msg</message>
                <stackTrace>stack</stackTrace>
            </fieldNames>
        </encoder>
    </appender>

    <root level="INFO">
        <springProfile name="prod,staging">
            <appender-ref ref="CONSOLE_JSON"/>
        </springProfile>
        <springProfile name="!prod &amp; !staging">
            <appender-ref ref="CONSOLE_PLAIN"/>
        </springProfile>
    </root>

    <!-- Framework noise -->
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.springframework.boot" level="INFO"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="com.sns" level="INFO"/>
</configuration>
